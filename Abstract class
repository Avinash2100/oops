abstract class Animal {

    // Abstract method
    abstract void sound();

    // Normal method
    void eat() {

        System.out.println("Animal is eating");
    }
}

// Child class
class Dog extends Animal {

    // Method implementation
    void sound() {

        System.out.println("Dog barks");
    }
}

public class AbstractDemo {

    public static void main(String[] args) {

        Dog d = new Dog();

        d.sound();

        d.eat();
    }
}
