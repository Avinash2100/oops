import java.sql.*;
public class StudentCRUD {
public static void main(String[] args) {
try {
Class.forName("com.mysql.cj.jdbc.Driver");
Connection con = DriverManager.getConnection(
"jdbc:mysql://localhost:3306/studentdb1",
"root",
"root"
);
Statement stmt = con.createStatement();
System.out.println("Initial Student Table:");
ResultSet rs = stmt.executeQuery("SELECT * FROM Student");
while (rs.next()) {
System.out.println(
rs.getInt("id") + "\t" +
rs.getString("name") + "\t" +
rs.getString("course") + "\t" +
rs.getInt("marks")
);
}
int rowsInserted = stmt.executeUpdate(
"INSERT INTO Student (name, course, marks) VALUES ('Rahul', 'AI', 90)"
);
System.out.println("\nRecord inserted. Rows affected: " + rowsInserted);
System.out.println("\nStudent Table After Insert:");
rs = stmt.executeQuery("SELECT * FROM Student");
while (rs.next()) {
System.out.println(
rs.getInt("id") + "\t" +
rs.getString("name") + "\t" +
rs.getString("course") + "\t" +
rs.getInt("marks")
);
}
int rowsDeleted = stmt.executeUpdate(
"DELETE FROM Student WHERE id = 1"
);
System.out.println("\nRecord deleted. Rows affected: " + rowsDeleted);
System.out.println("\nStudent Table After Delete:");
rs = stmt.executeQuery("SELECT * FROM Student");
while (rs.next()) {
System.out.println(
rs.getInt("id") + "\t" +
rs.getString("name") + "\t" +
rs.getString("course") + "\t" +
rs.getInt("marks")
);
}
con.close();
} catch (Exception e) {
System.out.println(e);
}
}
}
