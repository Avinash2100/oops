class ChatUser extends Thread {

    // Constructor
    ChatUser(String name) {

        super(name); // Set thread name
    }

    // Thread task
    public void run() {

        for (int i = 1; i <= 3; i++) {

            System.out.println(getName() + " : Message " + i);

            try {

                Thread.sleep(500);

            } catch (Exception e) {

                System.out.println(e);
            }
        }
    }
}

public class ChatSystem {

    public static void main(String[] args) throws Exception {

        // Create thread objects
        ChatUser u1 = new ChatUser("Alice");

        ChatUser u2 = new ChatUser("Bob");

        // Set priorities
        u1.setPriority(Thread.MIN_PRIORITY);

        u2.setPriority(Thread.MAX_PRIORITY);

        // Start threads
        u1.start();

        u2.start();

        // Check thread alive status
        System.out.println("Alice Alive: " + u1.isAlive());

        // Wait for threads to finish
        u1.join();

        u2.join();

        System.out.println("Chat finished.");
    }
}
